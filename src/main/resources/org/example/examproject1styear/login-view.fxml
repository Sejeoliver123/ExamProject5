<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="240.0" prefWidth="320.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.examproject1styear.gui.LoginController">

   <children>
      <TextField fx:id="txtUsername" layoutX="85.0" layoutY="76.0" prefHeight="25.0" prefWidth="149.0" promptText="Username" />
      <PasswordField fx:id="txtpassword" layoutX="85.0" layoutY="108.0" promptText="Password" />
      <Button fx:id="btnLogin" layoutX="137.0" layoutY="154.0" mnemonicParsing="false" onAction="#handleLogin" text="Login" />
      <Label fx:id="lblLoginError" layoutX="137.0" layoutY="196.0" prefHeight="17.0" prefWidth="250.0" textFill="#f20101" />
   </children>
</AnchorPane>
