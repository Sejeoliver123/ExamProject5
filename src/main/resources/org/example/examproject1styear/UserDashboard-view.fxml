<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.examproject1styear.gui.UserDashboardController">
   <children>
      <Button fx:id="btnScanning" layoutY="2.0" mnemonicParsing="false" text="Scanning" />
      <Button fx:id="logout" layoutX="548.0" layoutY="2.0" mnemonicParsing="false" onAction="#handleLogout" text="LogOut" />
      <TableView layoutY="200.0" prefHeight="200.0" prefWidth="235.0">
        <columns>
          <TableColumn prefWidth="75.0" text="Name" />
          <TableColumn prefWidth="75.0" text="Mail" />
            <TableColumn prefWidth="75.0" text="Role" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
